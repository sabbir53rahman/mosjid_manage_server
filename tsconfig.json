{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "node",
    "target": "es2023",
    "rootDir": "./",
    "outDir": "./dist",
    "types": ["node", "express"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}

