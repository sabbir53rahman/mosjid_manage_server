{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "node",
    "target": "es2023",
    "rootDir": "./",
    "outDir": "./dist",
    "types": ["node", ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "api", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}
