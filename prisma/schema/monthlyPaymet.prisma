model MonthlyPayment {
  id String @id @default(cuid())

  musulliId String

  billingMonth DateTime

  expectedAmount Float

  paidAmount Float @default(0)

  dueAmount Float

  status PaymentStatus @default(DUE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  musulli Musulli @relation(fields: [musulliId], references: [id], onDelete: Cascade)

  paymentLogs PaymentLog[]

  @@unique([musulliId, billingMonth])
  @@index([musulliId])
  @@index([billingMonth])
}

model PaymentLog {
  id String @id @default(cuid())

  monthlyPaymentId String

  musulliId String

  amount Float

  paymentDate DateTime @default(now())

  note String?

  createdAt DateTime @default(now())

  monthlyPayment MonthlyPayment @relation(fields: [monthlyPaymentId], references: [id], onDelete: Cascade)

  musulli Musulli @relation(fields: [musulliId], references: [id], onDelete: Cascade)

  @@index([monthlyPaymentId])
  @@index([musulliId])
}
