model Musulli {
  id String @id @default(cuid())

  mosqueId String

  name String

  phone String

  address String?

  image String?

  monthlyFee Float

  joinedAt DateTime

  totalPaid Float @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mosque Mosque @relation(fields: [mosqueId], references: [id], onDelete: Cascade)

  paymentLogs PaymentLog[]

  @@index([mosqueId])
  @@index([phone])
}

model PaymentLog {
  id String @id @default(cuid())

  musulliId String

  amount Float

  paidMonth DateTime

  note String?

  paymentDate DateTime @default(now())

  createdAt DateTime @default(now())

  musulli Musulli @relation(fields: [musulliId], references: [id], onDelete: Cascade)

  @@unique([musulliId, paidMonth])
  @@index([musulliId])
  @@index([paidMonth])
}
