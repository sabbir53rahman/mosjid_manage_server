model Admin {
  id              String        @id @default(cuid())

  mosqueId        String

  name            String

  email           String        @unique

  password        String

  phone           String?

  role            Role          @default(MOSQUE_ADMIN)

  isActive        Boolean       @default(true)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  mosque          Mosque        @relation(fields: [mosqueId], references: [id])

  @@index([mosqueId])
}
