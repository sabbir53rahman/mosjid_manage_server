# ===============================
# APP CONFIG
# ===============================
PORT=5000
FRONTEND_URL=http://localhost:3000

# ===============================
# DATABASE
# ===============================
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/mentor_booking

# ===============================
# AUTH (JWT)
# ===============================
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# ===============================
# EMAIL (SMTP)
# ===============================
EMAIL_SENDER_SMTP_FROM=your_email@gmail.com
EMAIL_SENDER_SMTP_USER=your_email@gmail.com
EMAIL_SENDER_SMTP_PASS=your_app_password
EMAIL_SENDER_SMTP_HOST=smtp.gmail.com
EMAIL_SENDER_SMTP_PORT=465

# ===============================
# GOOGLE AUTH
# ===============================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/callback/google

# ===============================
# CLOUDINARY
# ===============================
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_CLOUD_NAME=your_cloud_name

# ===============================
# STRIPE
# ===============================
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ===============================
# ADMIN
# ===============================
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=secure_password